# Copy to backend/.env and fill in. backend/.env is gitignored — never commit it.

# Shared Aura cloud DB over the HTTP Query API (works on campus Wi-Fi).
# Use the https:// host (NOT neo4j+s://) so the backend uses port 443.
NEO4J_URI=https://<aura-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# For local Bolt instead, use:  NEO4J_URI=bolt://localhost:7687

# Each developer uses their own Anthropic key.
ANTHROPIC_API_KEY=
